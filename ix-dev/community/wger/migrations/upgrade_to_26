#!/usr/bin/python3
import os
import sys
import yaml


def migrate(values):
    # wger 2.6: SYNC_INGREDIENTS_CELERY was removed from the server entrypoint.
    # The template no longer injects it, so no structural changes to user values
    # are needed for this release.
    return values


if __name__ == "__main__":
    if len(sys.argv) != 2:
        exit(1)

    if os.path.exists(sys.argv[1]):
        with open(sys.argv[1], "r") as f:
            print(yaml.dump(migrate(yaml.safe_load(f.read()))))
