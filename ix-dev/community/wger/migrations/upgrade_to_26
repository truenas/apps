#!/usr/bin/python3
import os
import sys
import yaml


def migrate(values):
    # wger 2.6: SIGNING_KEY was replaced by JWT_PRIVATE_KEY and JWT_PUBLIC_KEY.
    # Rename the stored signing_key → jwt_private_key so the user's old value is
    # preserved. jwt_public_key cannot be derived from signing_key, so it is set
    # to an empty string — TrueNAS will prompt the user to fill in the required
    # field after the upgrade.
    wger = values.get("wger", {})
    if isinstance(wger, dict) and "signing_key" in wger:
        wger["jwt_private_key"] = wger.pop("signing_key")
        wger.setdefault("jwt_public_key", "")
        values["wger"] = wger

    # wger 2.6: SITE_URL and REFRESH_TOKEN_LIFETIME are new required/recommended
    # fields. Set safe empty defaults so existing users are prompted to fill them in.
    if isinstance(wger, dict):
        wger.setdefault("site_url", "")
        wger.setdefault("refresh_token_lifetime", 3000)
        values["wger"] = wger

    return values


if __name__ == "__main__":
    if len(sys.argv) != 2:
        exit(1)

    if os.path.exists(sys.argv[1]):
        with open(sys.argv[1], "r") as f:
            print(yaml.dump(migrate(yaml.safe_load(f.read()))))
