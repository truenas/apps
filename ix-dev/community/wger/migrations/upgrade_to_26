#!/usr/bin/python3
import os
import sys
import yaml


def migrate(values):
    # wger 2.6: SIGNING_KEY was replaced by JWT_PRIVATE_KEY and JWT_PUBLIC_KEY.
    # Rename the stored signing_key → jwt_private_key so the user's old value is
    # preserved. jwt_public_key cannot be derived from signing_key; leave it absent
    # so TrueNAS prompts the user to fill in the required field after the upgrade.
    wger = values.get("wger", {})
    if isinstance(wger, dict) and "signing_key" in wger:
        wger["jwt_private_key"] = wger.pop("signing_key")
        # jwt_public_key cannot be derived from signing_key — leave absent so
        # TrueNAS surfaces it as a required field the user must fill in.
        values["wger"] = wger

    # wger 2.6: REFRESH_TOKEN_LIFETIME is new — a valid integer default is safe.
    # SITE_URL and JWT_PUBLIC_KEY are required URI/string fields; do NOT default
    # them to "" because empty strings fail required-field validation and will
    # break the upgrade. TrueNAS will prompt the user to supply those values.
    if isinstance(wger, dict):
        wger.setdefault("refresh_token_lifetime", 3000)
        values["wger"] = wger

    return values


if __name__ == "__main__":
    if len(sys.argv) != 2:
        exit(1)

    if os.path.exists(sys.argv[1]):
        with open(sys.argv[1], "r") as f:
            print(yaml.dump(migrate(yaml.safe_load(f.read()))))
